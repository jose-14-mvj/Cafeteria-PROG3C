<Window x:Class="Cafeteria.wpfProveedor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proveedores y Compras" Height="560" Width="620"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1A1D2E" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🏭 Proveedores" FontSize="15" FontWeight="Bold"
                   Foreground="#F59E0B" Margin="0,0,0,8"/>
        <ListBox Grid.Row="1" x:Name="lstProveedores" Background="#2D3158"
                 Foreground="White" BorderBrush="#4C4F7C" FontSize="12"/>

        <!-- Formulario proveedor -->
        <Grid Grid.Row="2" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtProvNombre"   Grid.Column="0" Margin="0,0,4,0"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Nombre empresa"/>
            <TextBox x:Name="txtProvTelefono" Grid.Column="1" Margin="0,0,4,0"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Teléfono"/>
            <Button  Grid.Column="2" Content="+ Guardar"
                     Background="#7C5A0B" Foreground="White" BorderThickness="0"
                     Cursor="Hand" Click="btnGuardarProv_Click"/>
        </Grid>

        <!-- Órdenes de compra -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="📋 Órdenes de Compra" FontSize="14" FontWeight="Bold"
                       Foreground="#F59E0B" Margin="0,0,0,8"/>
            <ListBox x:Name="lstOrdenes" Background="#2D3158" Foreground="#CBD5E1"
                     BorderBrush="#4C4F7C" Height="120" FontSize="12"/>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="80"/><ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtOrdProducto" Grid.Column="0" Margin="0,0,4,0"
                         Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                         Padding="6,4" ToolTip="Producto"/>
                <TextBox x:Name="txtOrdCantidad" Grid.Column="1" Margin="0,0,4,0"
                         Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                         Padding="6,4" ToolTip="Cantidad"/>
                <TextBox x:Name="txtOrdCosto"    Grid.Column="2" Margin="0,0,4,0"
                         Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                         Padding="6,4" ToolTip="Costo Bs."/>
                <Button  Grid.Column="3" Content="+ Orden"
                         Background="#0F6E56" Foreground="White" BorderThickness="0"
                         Cursor="Hand" Click="btnNuevaOrden_Click"/>
            </Grid>
        </StackPanel>

        <Button Grid.Row="4" Content="Cerrar" Height="34" Margin="0,10,0,0"
                Background="#374151" Foreground="#94A3B8" BorderThickness="0"
                Cursor="Hand" Click="btnCerrar_Click"/>
    </Grid>
</Window>
