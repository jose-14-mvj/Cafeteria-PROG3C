<Window x:Class="Cafeteria.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cafetería - Login" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#1A1D2E">
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Width="300">

            <TextBlock Text="CAFETERÍA" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="#A78BFA" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,4"/>
            
            <TextBlock Text="Sistema de Gestión" 
                       FontSize="13"
                       Foreground="#64748B" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"/>

            <TextBlock Text="Usuario:" 
                       Foreground="#CBD5E1" 
                       Margin="0,0,0,4"/>
            
            <TextBox x:Name="txtCorreo" 
                     Height="36" 
                     Background="#2D3158"
                     Foreground="White" 
                     BorderBrush="#4C4F7C" 
                     Padding="8,6"
                     FontSize="13" 
                     Margin="0,0,0,12"/>

            <TextBlock Text="Contraseña:" 
                       Foreground="#CBD5E1" 
                       Margin="0,0,0,4"/>
            
            <PasswordBox x:Name="txtPassword" 
                         Height="36" 
                         Background="#2D3158"
                         Foreground="White" 
                         BorderBrush="#4C4F7C" 
                         Padding="8,6"
                         FontSize="13" 
                         Margin="0,0,0,24"/>

            <Button x:Name="btnIngresar" 
                    Content="INGRESAR" 
                    Height="40"
                    Background="#6D28D9" 
                    Foreground="White" 
                    FontWeight="Bold"
                    FontSize="14" 
                    BorderThickness="0" 
                    Cursor="Hand"
                    Click="btnIngresar_Click" 
                    Margin="0,0,0,10"/>
            
            
            <Button x:Name="btnCrearCuenta" 
                     Content="Crear Cuenta" 
                     Height="40"
                     Background="#6D28D9" 
                     Foreground="White" 
                     FontWeight="Bold"
                     FontSize="14" 
                     BorderThickness="0" 
                     Cursor="Hand"
                     
                     Margin="0,0,0,10" Click="btnCrearCuenta_Click"/>

            <TextBlock x:Name="lblMensaje" 
                       Foreground="#F87171"
                       HorizontalAlignment="Center" 
                       FontSize="12"/>
            
        </StackPanel>
    </Grid>
</Window>
