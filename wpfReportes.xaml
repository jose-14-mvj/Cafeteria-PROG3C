<Window x:Class="Cafeteria.wpfReportes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reporte de Ventas" Height="520" Width="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1A1D2E" Margin="16">
        <StackPanel>
            <TextBlock Text="📊 Historial de Ventas" FontSize="16" FontWeight="Bold"
                       Foreground="#A78BFA" Margin="0,0,0,12"/>
            <ListBox x:Name="lstVentas" Background="#2D3158" Foreground="#CBD5E1"
                     BorderBrush="#4C4F7C" Height="360" FontSize="12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <TextBlock x:Name="lblTotalVentas" FontSize="13" Foreground="#FCD34D"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Cerrar" Width="90" Height="34"
                        Background="#374151" Foreground="#94A3B8"
                        BorderThickness="0" Cursor="Hand" Click="btnCerrar_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
