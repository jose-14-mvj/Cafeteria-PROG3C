<Window x:Class="Cafeteria.wpfMenuAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cafetería - Administrador" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#1A1D2E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="CAFETERÍA" FontSize="26" FontWeight="Bold"
                       Foreground="#A78BFA" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock x:Name="lblBienvenida" FontSize="13"
                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button Content="🍽  Gestionar Menú / Platos"  Height="44" Margin="0,0,0,10"
                    Background="#4C1D95" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnGestionMenu_Click"/>
            <Button Content="📦  Inventario de Productos"   Height="44" Margin="0,0,0,10"
                    Background="#4C1D95" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnInventario_Click"/>
            <Button Content="🏭  Proveedores y Compras"     Height="44" Margin="0,0,0,10"
                    Background="#4C1D95" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnProveedor_Click"/>
            <Button Content="📊  Reportes de Ventas"        Height="44" Margin="0,0,0,10"
                    Background="#4C1D95" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnReportes_Click"/>
            <Button Content="👥  Gestionar Empleados"       Height="44" Margin="0,0,0,20"
                    Background="#4C1D95" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnEmpleados_Click"/>

            <Button Content="Cerrar Sesión" Height="36"
                    Background="#374151" Foreground="#94A3B8" BorderThickness="0"
                    FontSize="12" Cursor="Hand" Click="btnSalir_Click"/>
        </StackPanel>
    </Grid>
</Window>
