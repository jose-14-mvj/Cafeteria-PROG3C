<Window x:Class="Cafeteria.wpfInventario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario de Productos" Height="520" Width="580"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1A1D2E" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="📦 Inventario de Productos" FontSize="16"
                   FontWeight="Bold" Foreground="#A78BFA" Margin="0,0,0,12"/>
        <ListBox Grid.Row="1" x:Name="lstInventario" Background="#2D3158"
                 Foreground="White" BorderBrush="#4C4F7C" FontSize="12"/>
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBox x:Name="txtProdNombre"  Grid.Column="0" Margin="0,0,4,4"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Nombre del producto"/>
            <TextBox x:Name="txtProdCateg"   Grid.Column="1" Margin="0,0,4,4"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Categoría"/>
            <TextBox x:Name="txtProdStock"   Grid.Column="2" Margin="0,0,4,4"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Stock actual"/>
            <TextBox x:Name="txtProdMinimo"  Grid.Column="3" Margin="0,0,4,4"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Stock mínimo"/>
            <TextBox x:Name="txtProdCosto"   Grid.Column="4"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Costo Bs."/>
            <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,6,0,0">
                <Button Content="+ Agregar"  Width="90" Height="32"
                        Background="#0F6E56" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="btnAgregar_Click" Margin="0,0,8,0"/>
                <Button Content="✕ Eliminar" Width="90" Height="32"
                        Background="#7F1D1D" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="btnEliminar_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
