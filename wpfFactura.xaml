<Window x:Class="Cafeteria.wpfFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Boleta Electrónica" Height="480" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#1A1D2E" Margin="20">
        <StackPanel>
            <TextBlock Text="======= BOLETA =======" FontSize="15" FontWeight="Bold"
                       Foreground="#FCD34D" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock x:Name="lblNumero" FontSize="12" Foreground="#94A3B8"
                       HorizontalAlignment="Center" Margin="0,0,0,2"/>
            <TextBlock x:Name="lblFecha"  FontSize="12" Foreground="#94A3B8"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock Text="Detalle:" FontSize="13" Foreground="#CBD5E1" Margin="0,0,0,4"/>
            <ListBox x:Name="lstDetalle" Background="#2D3158" Foreground="#CBD5E1"
                     BorderBrush="#4C4F7C" Height="200" FontSize="12"/>

            <Separator Background="#2D3158" Margin="0,12,0,8"/>
            <TextBlock x:Name="lblSubtotal"  Foreground="#94A3B8"  FontSize="12" HorizontalAlignment="Right"/>
            <TextBlock x:Name="lblImpuesto"  Foreground="#94A3B8"  FontSize="12" HorizontalAlignment="Right"/>
            <TextBlock x:Name="lblTotalFinal" Foreground="#FCD34D" FontSize="16"
                       FontWeight="Bold" HorizontalAlignment="Right" Margin="0,4,0,16"/>

            <TextBlock x:Name="lblEmpleado" Foreground="#64748B" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Button Content="✅ Guardar y Cerrar" Height="40"
                    Background="#0F6E56" Foreground="White" BorderThickness="0"
                    FontWeight="Bold" FontSize="13" Cursor="Hand"
                    Click="btnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
