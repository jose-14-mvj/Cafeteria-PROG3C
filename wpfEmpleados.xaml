<Window x:Class="Cafeteria.wpfEmpleados"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Empleados" Height="500" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1A1D2E" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="👥 Gestión de Empleados" FontSize="16"
                   FontWeight="Bold" Foreground="#A78BFA" Margin="0,0,0,10"/>
        <ListBox Grid.Row="1" x:Name="lstEmpleados" Background="#2D3158"
                 Foreground="White" BorderBrush="#4C4F7C" FontSize="12"
                 SelectionChanged="lstEmpleados_SelectionChanged"/>
        <Grid Grid.Row="2" Margin="0,10,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtEmpNombre"   Grid.Column="0" Margin="0,0,4,0"
                     Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                     Padding="6,4" ToolTip="Usuario (correo)"/>
            <PasswordBox x:Name="txtEmpPass" Grid.Column="1" Margin="0,0,4,0"
                         Background="#2D3158" Foreground="White" BorderBrush="#4C4F7C"
                         Padding="6,4" ToolTip="Contraseña"/>
            <ComboBox x:Name="cmbRol"        Grid.Column="2"
                      Background="#2D3158" Foreground="Black" BorderBrush="#4C4F7C">
                <ComboBoxItem Content="Empleado" IsSelected="True"/>
                <ComboBoxItem Content="Administrador"/>
            </ComboBox>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="+ Agregar"  Width="90" Height="32"
                    Background="#0F6E56" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnAgregar_Click" Margin="0,0,8,0"/>
            <Button Content="✕ Eliminar" Width="90" Height="32"
                    Background="#7F1D1D" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnEliminar_Click"/>
        </StackPanel>
    </Grid>
</Window>
