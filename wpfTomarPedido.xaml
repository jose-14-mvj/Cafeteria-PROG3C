<Window x:Class="Cafeteria.wpfTomarPedido"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tomar Pedido" Height="580" Width="680"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1A1D2E" Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- IZQUIERDA: lista de platos -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock Text="Menú disponible" FontSize="16" FontWeight="Bold"
                       Foreground="#2DD4BF" Margin="0,0,0,10"/>
            <ListBox x:Name="lstPlatos" Background="#2D3158" Foreground="White"
                     BorderBrush="#4C4F7C" Height="340" FontSize="13"
                     SelectionChanged="lstPlatos_SelectionChanged"/>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cantidad:" Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="txtCantidad" Grid.Column="1" Text="1"
                         Background="#2D3158" Foreground="White"
                         BorderBrush="#4C4F7C" Padding="6,4" FontSize="13"/>
                <Button  Grid.Column="2" Content="+ Agregar"
                         Background="#0F6E56" Foreground="White"
                         BorderThickness="0" Cursor="Hand"
                         Click="btnAgregar_Click" Margin="8,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- DERECHA: pedido actual -->
        <StackPanel Grid.Column="1">
            <TextBlock Text="Pedido actual" FontSize="15" FontWeight="Bold"
                       Foreground="#A78BFA" Margin="0,0,0,10"/>
            <ListBox x:Name="lstPedido" Background="#2D3158" Foreground="#CBD5E1"
                     BorderBrush="#4C4F7C" Height="300" FontSize="12"/>
            <Button Content="✕ Quitar seleccionado" Height="32" Margin="0,6,0,0"
                    Background="#4B1505" Foreground="#FCA5A5" BorderThickness="0"
                    FontSize="11" Cursor="Hand" Click="btnQuitar_Click"/>
            <Separator Background="#2D3158" Margin="0,12,0,8"/>
            <TextBlock x:Name="lblTotal" Text="Total: Bs. 0.00"
                       FontSize="16" FontWeight="Bold" Foreground="#FCD34D"
                       HorizontalAlignment="Right" Margin="0,0,0,12"/>
            <Button Content="💳 Confirmar y Facturar" Height="44"
                    Background="#6D28D9" Foreground="White" BorderThickness="0"
                    FontWeight="Bold" FontSize="13" Cursor="Hand"
                    Click="btnFacturar_Click"/>
            <Button Content="Cancelar" Height="34" Margin="0,8,0,0"
                    Background="#374151" Foreground="#94A3B8"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="btnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
